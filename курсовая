            tickformat="%M:%S",
            title="Время",
            range=[start_time_limit, end_time_limit]
        )

        fig.for_each_trace(lambda trace: trace.update(showlegend=False) if trace.name == "_empty" else ())

        st.plotly_chart(fig, use_container_width=True)

        if len(raw_detections) == 0:
            st.info("Деструктивный контент не найден.")

        st.json(report_data)

        json_string = json.dumps(report_data, ensure_ascii=False, indent=2)
        st.download_button(
            label="Скачать отчет JSON",
            file_name="moderation_report.json",
            mime="application/json",
            data=json_string,
        )
