            st.stop()

        with st.spinner(f"Поиск объектов через {selected_yolo_model}..."):
            try:
                yolo_model = YOLO(model_path)

                custom_classes = [
                    "person smoking a cigarette", "white cigarette", "cigarette in mouth", "cigar",
                    "small white pill bottle", "small orange pill bottle", "white medical pills", "medical syringe",
                    "beer bottle", "wine bottle", "liquor bottle", "glass of whiskey", "glass of wine", "glass of beer"
                ]
                yolo_model.set_classes(custom_classes)

                cap = cv2.VideoCapture(video_path)
                fps = int(cap.get(cv2.CAP_PROP_FPS))
                if fps <= 0: fps = 30
                st.session_state['fps'] = fps

                width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
                height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
                frame_area = width * height

                fourcc = cv2.VideoWriter_fourcc(*'mp4v')
                temp_yolo = "temp_yolo_raw.mp4"
                out_video = cv2.VideoWriter(temp_yolo, fourcc, fps, (width, height))

                max_process_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
                if max_process_frames <= 0:
                    max_process_frames = fps * 180
                if max_process_frames > fps * 300:
                    max_process_frames = fps * 300

                count = 0
                yolo_events = []
                last_boxes = []

                yolo_bar = st.progress(0.0, text="Подготовка к сканированию...")

                process_step = max(1, int(fps / 2))

                while cap.isOpened() and count < max_process_frames:
                    ret, frame = cap.read()
                    if not ret: break

                    annotated_frame = frame.copy()

                    if count % process_step == 0:
                        results = yolo_model(frame, conf=0.01, verbose=False, device="cpu", imgsz=1024)

                        last_boxes = []
                        detected_in_frame = {}

                        if len(results[0].boxes) > 0:
                            names = yolo_model.names
                            boxes = results[0].boxes.xyxy.cpu().numpy()
                            clss = results[0].boxes.cls.cpu().numpy()
                            confs = results[0].boxes.conf.cpu().numpy()

                            for box, cls, conf in zip(boxes, clss, confs):
                                x1, y1, x2, y2 = float(box[0]), float(box[1]), float(box[2]), float(box[3])
                                box_area = (x2 - x1) * (y2 - y1)
                                ratio = box_area / frame_area

                                name = names[int(cls)]
                                raw_conf = float(conf)

                                boost = 0.65
                                mult = 2.5

                                if name == "person smoking a cigarette":
                                    if raw_conf < 0.015 or ratio < 0.02 or ratio > 0.90:
                                        continue
                                    boost = 0.69
                                    mult = 3.0
                                elif name in ["white cigarette", "cigarette in mouth", "cigar", "medical syringe"]:
                                    if raw_conf < 0.035 or ratio > 0.05:
                                        continue
                                elif name in ["small white pill bottle", "small orange pill bottle",
                                              "white medical pills"]:
                                    if raw_conf < 0.05 or ratio > 0.08:
                                        continue
                                elif name in ["beer bottle", "wine bottle", "liquor bottle"]:
                                    if raw_conf < 0.08 or ratio > 0.25:
                                        continue
                                elif name in ["glass of whiskey", "glass of wine", "glass of beer"]:
                                    if raw_conf < 0.06 or ratio > 0.20:
                                        continue
                                else:
                                    continue

                                final_conf = min(0.99, boost + raw_conf * mult)

                                if final_conf < conf_thresh:
                                    continue

                                if name not in detected_in_frame or final_conf > detected_in_frame[name]:
                                    detected_in_frame[name] = final_conf

                                last_boxes.append((box, name, final_conf))

                        if detected_in_frame:
                            time_sec = count / fps
                            yolo_events.append({
                                "time": time_sec,
                                "frame": count,
                                "objects": detected_in_frame
                            })

                    for box, name, conf in last_boxes:
                        x1, y1, x2, y2 = int(box[0]), int(box[1]), int(box[2]), int(box[3])
                        cv2.rectangle(annotated_frame, (x1, y1), (x2, y2), (0, 255, 0), 2)
                        label = f"{name} {conf:.2f}"
                        (tw, th), _ = cv2.getTextSize(label, cv2.FONT_HERSHEY_SIMPLEX, 0.5, 2)
                        cv2.rectangle(annotated_frame, (x1, y1 - th - 5), (x1 + tw, y1), (0, 255, 0), -1)
                        cv2.putText(annotated_frame, label, (x1, y1 - 5), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 0, 0), 2)

                    out_video.write(annotated_frame)

                    count += 1
                    if count % 5 == 0 or count == max_process_frames:
                        progress_val = min(count / max_process_frames, 1.0)
                        yolo_bar.progress(progress_val,
                                          text=f"Анализ видео: обработан кадр {count} из {max_process_frames}")

                cap.release()
                out_video.release()

                subprocess.run(["ffmpeg", "-y", "-i", temp_yolo, "-vcodec", "libx264", "output_yolo.mp4"],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

                st.session_state['yolo_events'] = yolo_events
                st.session_state['frame_count'] = count

                del yolo_model
                gc.collect()
                if torch.backends.mps.is_available():
                    torch.mps.empty_cache()

                st.success("Сканирование объектов завершено.")
            except Exception as e:
                error_msg = str(e)
                if any(kw in error_msg for kw in
                       ["zip archive", "corrupted", "PytorchStreamReader", "SHA256", "checksum"]):
                    if os.path.exists(model_path):
                        try:
                            os.remove(model_path)
