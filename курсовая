def cleanup_temp_files():
    files_to_remove = ["temp_video.mp4", "temp_audio/audio.wav", "temp_yolo_raw.mp4", "output_yolo.mp4"]
    for f in files_to_remove:
        if os.path.exists(f):
            os.remove(f)
    for f in os.listdir("temp_frames"):
        if f.endswith(".jpg"):
            os.remove(os.path.join("temp_frames", f))


def format_time(seconds):
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = int(seconds % 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def extract_frames(video_path, max_frames=1800):
    cap = cv2.VideoCapture(video_path)
    fps = cap.get(cv2.CAP_PROP_FPS)
    if fps <= 0:
        fps = 30
    saved = 0
    frame_step = int(fps)
    while cap.isOpened() and saved < max_frames:
        cap.set(cv2.CAP_PROP_POS_FRAMES, saved * frame_step)
        ret, frame = cap.read()
        if not ret:
            break
        cv2.imwrite(f"temp_frames/frame_{saved}.jpg", frame)
        saved += 1
    cap.release()
    st.session_state['fps'] = fps


def download_rutube(url):
    ydl_opts = {
        'outtmpl': 'temp_video.mp4',
        'format': 'best',
        'quiet': True
    }
    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        ydl.download([url])
    return 'temp_video.mp4'


def clean_text(text):
    cleaned = re.sub(r'[^а-яА-ЯёЁa-zA-Z0-9\s.,!?_\[\]]', '', text)
    cleaned = re.sub(r'\s+', ' ', cleaned).strip()
    return cleaned


