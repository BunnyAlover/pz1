    if st.button("Начать извлечение") and os.path.exists("temp_frames/frame_0.jpg"):
        frames = [f for f in os.listdir("temp_frames") if f.endswith(".jpg")]
        frames.sort(key=lambda x: int(x.split('_')[1].split('.')[0]))

        ocr_events = []
        my_bar = st.progress(0, text="Распознавание текста...")
        fps = st.session_state.get('fps', 30)

        for idx, filename in enumerate(frames):
            frame_idx = int(filename.split('_')[1].split('.')[0])
            time_sec = float(frame_idx)

            img = cv2.imread(os.path.join("temp_frames", filename))
            h, w = img.shape[:2]
            roi = img[int(h * 0.7):h, :]

            gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)
            _, thresh = cv2.threshold(gray, 200, 255, cv2.THRESH_BINARY_INV)

            text = pytesseract.image_to_string(thresh, lang='rus+eng', config='--psm 6')
            clean = clean_text(text)

            if len(clean) >= 5:
                ocr_events.append({"time": time_sec, "text": clean})

            my_bar.progress((idx + 1) / len(frames), text="Распознавание текста...")

        st.session_state['ocr_events'] = ocr_events

        with st.spinner(f"Транскрибация аудиодорожки (модель {selected_model_name})..."):
            audio_path = "temp_audio/audio.wav"
            subprocess.run(
                ["ffmpeg", "-y", "-i", video_path, "-vn", "-acodec", "pcm_s16le", "-ar", "16000", "-ac", "1",
                 audio_path],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

            whisper_model = whisper.load_model(selected_model_name)
            audio_result = whisper_model.transcribe(audio_path, condition_on_previous_text=False, word_timestamps=True)

            audio_events = []
            for segment in audio_result["segments"]:
                words_data = []
                if "words" in segment:
                    for w in segment["words"]:
                        words_data.append({
                            "word": clean_text(w["word"]),
                            "start": w["start"],
                            "end": w["end"]
                        })

                audio_events.append({
                    "start": segment["start"],
                    "end": segment["end"],
                    "text": clean_text(segment["text"]),
                    "words": words_data
                })

            st.session_state['audio_events'] = audio_events

            del whisper_model
            gc.collect()
            if torch.backends.mps.is_available():
                torch.mps.empty_cache()

        st.success("Текст и аудио извлечены с таймкодами.")

    if 'audio_events' in st.session_state:
        st.write("Распознанные субтитры из аудиодорожки:")
        audio_df = pd.DataFrame(st.session_state['audio_events'])
        if 'words' in audio_df.columns:
            audio_df = audio_df.drop(columns=['words'])
        audio_df['start'] = audio_df['start'].apply(format_time)
        audio_df['end'] = audio_df['end'].apply(format_time)
        audio_df.columns = ['Начало', 'Конец', 'Текст']
        st.dataframe(audio_df, use_container_width=True)

